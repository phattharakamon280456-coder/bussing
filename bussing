<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ระบบจองที่นั่งรถบัส (32 ที่นั่ง)</title>
  <style>
    * { box-sizing: border-box; font-family: 'Sukhumvit Set', 'Segoe UI', Tahoma, sans-serif; }
    body { background-color: #f4f7f6; display: flex; justify-content: center; padding: 20px; margin: 0; }
    
    .container { display: flex; gap: 30px; background: white; padding: 30px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.08); max-width: 900px; width: 100%; flex-wrap: wrap; }
    
    /* กรอบรถบัส */
    .bus-container { flex: 1; min-width: 300px; background: #eef2f5; border: 3px solid #cbd5e1; border-radius: 40px 40px 20px 20px; padding: 20px; position: relative; }
    .driver-section { text-align: right; font-weight: bold; padding: 10px; border-bottom: 2px dashed #94a3b8; margin-bottom: 20px; color: #64748b; }
    
    /* ผังที่นั่ง */
    .seats-grid { display: flex; flex-direction: column; gap: 12px; }
    .row { display: flex; justify-content: space-between; align-items: center; }
    .seat-group { display: flex; gap: 8px; }
    .aisle { width: 30px; text-align: center; color: #cbd5e1; font-size: 12px; }
    
    /* ปุ่มที่นั่ง */
    .seat { width: 42px; height: 42px; border-radius: 8px; border: none; background-color: #3b82f6; color: white; font-weight: bold; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
    .seat:hover:not(.booked) { transform: scale(1.08); opacity: 0.9; }
    .seat.selected { background-color: #eab308; color: #0f172a; }
    .seat.booked { background-color: #94a3b8; cursor: not-allowed; opacity: 0.6; }
    
    /* แถวหลังสุด 4 ที่นั่ง */
    .back-row { display: flex; justify-content: space-between; gap: 8px; margin-top: 10px; padding-top: 10px; border-top: 2px dashed #cbd5e1; }
    .back-row .seat { flex: 1; }

    /* ฝั่งสรุปข้อมูล */
    .summary-panel { flex: 1; min-width: 280px; display: flex; flex-direction: column; justify-content: space-between; }
    .legend { display: flex; gap: 15px; margin-bottom: 20px; }
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: 14px; }
    .legend-box { width: 18px; height: 18px; border-radius: 4px; }

    .details-card { background: #f8fafc; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; margin-bottom: 20px; }
    .btn-submit { width: 100%; padding: 14px; background: #22c55e; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; transition: background 0.2s; }
    .btn-submit:hover { background: #16a34a; }
    .btn-submit:disabled { background: #cbd5e1; cursor: not-allowed; }
  </style>
</head>
<body>

<div class="container">
  <!-- ผังที่นั่งรถบัส -->
  <div class="bus-container">
    <div class="driver-section">🚍 คนขับ</div>
    
    <div class="seats-grid" id="mainSeats"></div>
    <div class="back-row" id="backSeats"></div>
  </div>

  <!-- สรุปและยืนยัน -->
  <div class="summary-panel">
    <div>
      <h2>ระบบจองที่นั่งรถบัส</h2>
      <div class="legend">
        <div class="legend-item"><div class="legend-box" style="background:#3b82f6;"></div> ว่าง</div>
        <div class="legend-item"><div class="legend-box" style="background:#eab308;"></div> เลือกอยู่</div>
        <div class="legend-item"><div class="legend-box" style="background:#94a3b8;"></div> จองแล้ว</div>
      </div>

      <div class="details-card">
        <h3>สรุปรายการ</h3>
        <p>ที่นั่งที่เลือก: <strong id="selectedSeatsText">ยังไม่ได้เลือก</strong></p>
        <p>จำนวนทั้งหมด: <strong id="countText">0</strong> / 32 ที่นั่ง</p>
      </div>
    </div>

    <button class="btn-submit" id="btnConfirm" disabled onclick="confirmBooking()">ยืนยันการจอง</button>
  </div>
</div>

<script>
  // จำลองที่นั่งที่ถูกจองไปแล้ว (เช่น ที่นั่งหมายเลข 3 และ 12)
  const bookedSeats = [3, 12];
  const selectedSeats = new Set();

  const mainSeatsContainer = document.getElementById('mainSeats');
  const backSeatsContainer = document.getElementById('backSeats');

  let seatNumber = 1;

  // สร้างแถว 1 - 7 (แถวละ 4 ที่นั่ง แบ่งซ้าย 2 ขวา 2)
  for (let r = 1; r <= 7; r++) {
    const rowDiv = document.createElement('div');
    rowDiv.className = 'row';

    const leftGroup = document.createElement('div');
    leftGroup.className = 'seat-group';
    for (let i = 0; i < 2; i++) {
      leftGroup.appendChild(createSeatElement(seatNumber++));
    }

    const aisle = document.createElement('div');
    aisle.className = 'aisle';
    aisle.innerText = '';

    const rightGroup = document.createElement('div');
    rightGroup.className = 'seat-group';
    for (let i = 0; i < 2; i++) {
      rightGroup.appendChild(createSeatElement(seatNumber++));
    }

    rowDiv.appendChild(leftGroup);
    rowDiv.appendChild(aisle);
    rowDiv.appendChild(rightGroup);
    mainSeatsContainer.appendChild(rowDiv);
  }

  // สร้างแถวหลังสุด (4 ที่นั่งติดกัน)
  for (let i = 0; i < 4; i++) {
    backSeatsContainer.appendChild(createSeatElement(seatNumber++));
  }

  function createSeatElement(number) {
    const btn = document.createElement('button');
    btn.className = 'seat';
    btn.innerText = number;

    if (bookedSeats.includes(number)) {
      btn.classList.add('booked');
    } else {
      btn.onclick = () => toggleSeat(number, btn);
    }
    return btn;
  }

  function toggleSeat(number, element) {
    if (selectedSeats.has(number)) {
      selectedSeats.delete(number);
      element.classList.remove('selected');
    } else {
      selectedSeats.add(number);
      element.classList.add('selected');
    }
    updateSummary();
  }

  function updateSummary() {
    const arr = Array.from(selectedSeats).sort((a, b) => a - b);
    document.getElementById('selectedSeatsText').innerText = arr.length > 0 ? arr.join(', ') : 'ยังไม่ได้เลือก';
    document.getElementById('countText').innerText = arr.length;
    document.getElementById('btnConfirm').disabled = arr.length === 0;
  }

  function confirmBooking() {
    alert(`บันทึกการจองสำเร็จ! ที่นั่ง: ${Array.from(selectedSeats).join(', ')}`);
  }
</script>

</body>
</html>
